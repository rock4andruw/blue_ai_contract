    UI["🖥 Demo UI<br/>上傳 / 範例模式 v2–v5"]
    API["🔌 FastAPI<br/>POST /compare · GET /example · GET /health"]
    PIPE["⚙️ 核心管道<br/>Parser → Align → Diff → Risk(15) → LLM → Report"]
    STORE["💾 本地資料<br/>sla_contract v1–v5 · gold_annotations(38) · 公司文件"]
    EVAL["📐 指標<br/>High-risk Recall 100% · Overall 61%"]
    UI --> API --> PIPE
    STORE --> PIPE
    EVAL --> PIPE
end

subgraph P15["🟡 Phase 1.5 — MAS 雙重驗證（已完成）"]
    direction TB
    SK1["📋 contract-risk-analysis.md<br/>Agent A 知識庫：最壞情況場景表"]
    SK2["💬 negotiation-strategy.md<br/>Agent B 知識庫：台灣業界慣例表"]
    MA["🔴 Agent A（嚴格）<br/>極度保守買方法律顧問<br/>最壞情況視角"]
    MB["🟡 Agent B（平衡）<br/>促成交易商務法務<br/>台灣 SaaS 業界慣例視角"]
    JG["⚖️ Judge 矩陣<br/>gap=0/1 → ✓ confirmed<br/>gap=2 → ⚠ pending"]
    SK1 --> MA
    SK2 --> MB
    MA --> JG
    MB --> JG
end

subgraph P2["🔵 Phase 2 — 能力擴展（3–6 月）"]
    direction TB
    PG["🗄 PostgreSQL + pgvector<br/>標準條款庫 · 語意檢索"]
    LAW["⚖️ Taiwan Law MCP<br/>個資法 / 民法 條文引用"]
    O365["📧 Office 365 MCP<br/>Teams 通知 · SharePoint 歸檔"]
    CTYPE["📄 合約類型擴展<br/>NDA · 採購合約 · LOI"]
    HETERO["🎭 異質模型 MAS<br/>Gemini Agent A + Claude Agent B<br/>消除 Echo Chamber"]
end

subgraph P3["🟣 Phase 3 — 企業級產品化（6–12 月）"]
    direction TB
    MAS["🎭 Multi-Agent System<br/>Orchestrator / Risk / Retrieval / LLM / Report / Notify"]
    ENT["🔐 企業功能<br/>RBAC 三層權限 · History Agent · 週報整併"]
    MAS --> ENT
end

subgraph EXT["☁️ 外部服務"]
    direction TB
    CLAUDE["🟠 Claude API<br/>claude-sonnet-4-6"]
    GEMINI["🔵 Gemini API<br/>gemini-3.1-flash-lite"]
    AZURE["🔷 Azure Cloud<br/>Blob Storage · AD 認證 · App Insights"]
end

